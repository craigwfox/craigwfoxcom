{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "postSlug": {
      "type": "string"
    },
    "categories": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "type": {
      "type": "string"
    },
    "trail": {
      "type": "string"
    },
    "location": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "difficulty": {
      "type": "string"
    },
    "parkWebsite": {
      "type": "string"
    },
    "allTrails": {
      "type": "string"
    },
    "noSingle": {
      "type": "boolean"
    },
    "miles": {
      "type": "number"
    },
    "pubDate": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "string",
          "format": "date-time"
        }
      ]
    },
    "updatedDate": {
      "type": "string"
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "description",
    "postSlug",
    "type",
    "trail",
    "location",
    "difficulty",
    "parkWebsite",
    "allTrails",
    "pubDate"
  ]
}